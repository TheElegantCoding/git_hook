{
  "name": "git_hook",
  "description": "",
  "author": "Luis Monsalve",
  "version": "1.0.0",
  "homepage": "https://s#readme",
  "repository": {
    "type": "git",
    "url": "git+https:"
  },
  "keywords": [
    "logger",
    "logging",
    "typescript",
    "browser-logs",
    "node-logger",
    "isomorphic-logger",
    "debug",
    "console"
  ],
  "bugs": {
    "url": "https:/"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["./dist"],
  "engines": {
    "node": ">=22.17.0",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "preinstall": "npx only-allow bun",
    "postinstall": "git config core.hooksPath ./.git/hooks",
    "install": "bun src/util/install.ts",
    "commit:check": "bun src/playground/lint_commit.ts",
    "lint:staged": "bun src/playground/lint_staged.ts"
  },
  "dependencies": {
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "eslint-config-universal-code": "^1.0.13",
    "logginlys": "^1.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}