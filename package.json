{
  "name": "gitlys",
  "description": "📦️ A lightweight, zero-dependency release automation toolkit for Node.js and Bun. Handles semantic versioning, categorized changelogs, and automated GitHub releases",
  "author": "Luis Monsalve",
  "version": "1.0.6",
  "homepage": "https://github.com/TheElegantCoding/gitlys#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheElegantCoding/gitlys.git"
  },
  "keywords": [
    "release",
    "semantic-release",
    "changelog",
    "typescript",
    "github",
    "git",
    "bash",
    "design-pattern",
    "performance",
    "clean-code",
    "lint-staged",
    "commitlint",
    "conventional-commits",
    "release-automation",
    "versioning",
    "versioning-control",
    "git-hooks",
    "release-notes",
    "release"
  ],
  "bugs": {
    "url": "https://github.com/TheElegantCoding/gitlys/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "gitlys": "dist/cli.js"
  },
  "files": ["./dist"],
  "engines": {
    "node": ">=22.17.0",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "build": "tsup --entry.index=src/index.ts --entry.cli=src/module/cli/cli.ts --format esm --clean --minify --dts",
    "postinstall": "git config core.hooksPath ./.git/hooks",
    "preinstall": "npx only-allow bun",
    "install": "bun src/util/install.ts",
    "commit:check": "bun src/playground/lint_commit.ts",
    "lint-staged:check": "bun src/playground/lint_staged.ts",
    "changelog:check": "bun src/playground/changelog.ts",
    "release:check": "bun src/playground/release.ts",
    "lint": "eslint --fix",
    "release": "bun run build && bun src/playground/release.ts",
    "publish": "npm publish"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "eslint-config-universal-code": "^1.0.13",
    "logginlys": "^2.0.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
