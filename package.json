{
  "name": "gitlys",
  "description": "A lightweight, zero-dependency release automation toolkit for Node.js and Bun. Handles semantic versioning, categorized changelogs, and automated GitHub releases",
  "author": "Luis Monsalve",
  "version": "0.0.0",
  "homepage": "https://s#readme",
  "repository": {
    "type": "git",
    "url": "git+https:"
  },
  "keywords": [
    "logger",
    "logging",
    "typescript",
    "browser-logs",
    "node-logger",
    "isomorphic-logger",
    "debug",
    "console"
  ],
  "bugs": {
    "url": "https:/"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "gitlys": "./dist/bin/cli.js"
  },
  "files": ["./dist"],
  "engines": {
    "node": ">=22.17.0",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "build": "tsup src/index.ts src/bin/cli.ts src/util/install.ts --format esm --dts --clean",
    "postinstall": "git config core.hooksPath ./.git/hooks",
    "preinstall": "npx only-allow bun",
    "install": "bun src/util/install.ts",
    "commit:check": "bun src/playground/lint_commit.ts",
    "lint:staged": "bun src/playground/lint_staged.ts",
    "lint": "eslint --fix",
    "release": "bun run build && bun src/playground/release.ts && bun publish --access public"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "eslint-config-universal-code": "^1.0.13",
    "logginlys": "^1.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
